rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidChatSession(data, userId) {
      return data.keys().hasAll(['userId', 'title', 'updatedAt', 'messages']) &&
             data.keys().size() == 4 &&
             data.userId == userId &&
             data.title is string && data.title.size() <= 100 &&
             data.updatedAt is number &&
             data.messages is list && data.messages.size() <= 200;
    }

    match /users/{userId}/sessions/{sessionId} {
      allow read: if isOwner(userId);
      
      allow create: if isOwner(userId) && 
        isValidId(userId) && isValidId(sessionId) &&
        isValidChatSession(incoming(), userId);
        
      allow update: if isOwner(userId) && 
        isValidId(userId) && isValidId(sessionId) &&
        isValidChatSession(incoming(), userId) &&
        incoming().userId == existing().userId &&
        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'updatedAt', 'messages']);
        
      allow delete: if isOwner(userId) && isValidId(userId) && isValidId(sessionId);
    }
  }
}
